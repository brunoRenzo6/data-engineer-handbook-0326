-- lab-3__ddl


create type vertex_type as enum (
	'player', 'team', 'game'
)
;


create type edge_type as enum (
	'plays_against',
	'shares_team',
	'plays_in', -- plays in a game
	'plays_on' -- plays on a team
)
;

create table vertex (
	identifier varchar,
	type vertex_type,
	properties JSON,
	primary key (identifier, type)
)
;


create table edge (
	subj_identifier varchar,
	subj_type vertex_type,
	obj_identifier varchar,
	obj_type vertex_type,
	-- edge_identifier varchar,
	type edge_type,
	properties JSON,
	primary key (
		subj_identifier, subj_type,
		obj_identifier, obj_type,
		type
	)
)
;



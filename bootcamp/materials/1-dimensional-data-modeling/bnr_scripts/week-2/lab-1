-- # quick analytics



-- Players that have the highest pts diff between home and away games
with a as(
	select
	dim_player_id, 
	-- count(*) as n_games, 
	-- sum(m_pts) as sum_pts,
	sum(case when dim_is_home_team then 1 else 0 end) as n_games_home,
	sum(case when dim_is_home_team then 0 else 1 end) as n_games_away,
	sum(case when dim_is_home_team then m_pts else 0 end) as sum_pts_home,
	sum(case when dim_is_home_team then 0 else m_pts end) as sum_pts_away
	from fct_game_details
	group by dim_player_id
),
b as (
	select 
	*,
	case 
		when n_games_home=0 then 0
		else round(sum_pts_home::numeric/n_games_home, 2)
	end as pts_per_game_home,
	case 
		when n_games_away=0 then 0
		else round(sum_pts_away::numeric/n_games_away, 2)
	end as pts_per_game_away
	from a
)
select 
gd.player_name, 
b.* 
from b
left join (select distinct player_id, player_name from game_details) as gd
	on b.dim_player_id = gd.player_id
where pts_per_game_home is not null
	and pts_per_game_away is not null
	and n_games_home>30
	and n_games_away>30
order by abs(pts_per_game_home - pts_per_game_away) desc
;


-- ## Quick analytical queries


-- sum metric by day
with a as (
	select 
		user_id, 
		metric_name,
		month_start,
		month_start + (index-1) * ('1 days'::interval) as date,
		metric_value
	from array_metrics
	cross join unnest(metric_array) with ordinality as a(metric_value, index)
	where month_start = '2023-01-01'
)
select
user_id, 
metric_name, 
month_start, 
date,
sum(metric_value) as sum_metric_value
from a
group by user_id, metric_name, month_start, date 
order by user_id, metric_name, month_start, date 
;


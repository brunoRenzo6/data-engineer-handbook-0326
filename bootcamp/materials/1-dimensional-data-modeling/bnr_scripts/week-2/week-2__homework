-- (quick_note) Zach mentions that the type should be MAP<STRING, ARRAY[DATE]>,
--   but in postgreSQL map is actually a json, 
--   and json does not enforce that all values have same type.


-- tracks users active days by device
drop table user_devices_cumulated;
create table user_devices_cumulated (
	user_id numeric,
	browser_type text,
	date date,
	device_activity_datelist date[],
	primary key (user_id, browser_type, date)
)
;


-- # A monthly, reduced fact table DDL host_activity_reduced

create table host_activity_reduced (
	host text,
	month date,
	hit_array integer[],
	unique_visitors_array integer[],
	primary key (host, month)
);



----------------------------------------------------------------
-- # An incremental query that loads host_activity_reduced


insert into host_activity_reduced
with prev_har as (
	select
	*
	from host_activity_reduced
	where month = date_trunc('month', '2023-01-07'::date)
),
today as (
	select
	host,
	count(*) as hits,
	count(distinct user_id) as unique_visitors,
	event_time::date as date,
	date_trunc('month', event_time::date)::date as month
	from events
	where event_time::date = '2023-01-07'
	group by host, event_time::date
)
select
	coalesce(t.host, phar.host) as host,
	coalesce(t.month, phar.month)::date as month,
	case
		when t.host is null
			then phar.hit_array
		when phar.host is null
			then array_fill(0, array[t.date - t.month]) || array[t.hits]
		else
			phar.hit_array || array[t.hits]
	end as hit_array,
	case 
		when t.host is null
			then phar.unique_visitors_array
		when phar.host is null
			then array_fill(0, array[t.date - t.month]) || array[t.unique_visitors]
		else
			phar.unique_visitors_array || array[t.unique_visitors]
	end as unique_visitors_array
from prev_har phar
full outer join today t
	on phar.host = t.host
on conflict (host, month)
	do update set 
	(host, month, hit_array, unique_visitors_array)
	=
	(EXCLUDED.host, EXCLUDED.month, EXCLUDED.hit_array, EXCLUDED.unique_visitors_array)
;


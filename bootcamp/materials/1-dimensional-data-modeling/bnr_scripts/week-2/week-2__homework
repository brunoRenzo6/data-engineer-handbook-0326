-- 2023-01-01, 2023-01-31



insert into user_devices_cumulated
with prev_udc as (
	select *
	from user_devices_cumulated
	where date = '2023-01-07'
),
today as (
	select
		distinct 
		user_id, 
		device_id,
		cast(event_time as date) as date
	from events
	where 
		cast(event_time as date) = '2023-01-08'
		and user_id is not null
		and device_id is not null
),
today_browsers as (
	select
	t.user_id, 
	d.browser_type,
	array[t.date] as datelist
	from today t
	left join devices d
		on t.device_id = d.device_id
	group by t.user_id, d.browser_type, t.date -- just for safety
),
prev_udc_typed as (
	select
		p.user_id, 
		exploded_json.key as browser_type,
		date,
		array_agg(explored_array.value::date order by explored_array.value::date desc) as datelist
	from prev_udc p
	join lateral json_each(device_activity_datelist) as exploded_json on 1=1 
	join lateral json_array_elements_text(exploded_json.value) as explored_array on 1=1
	where date - explored_array.value::date < 6
	group by p.user_id, exploded_json.key, date
),
j_json_exploded as (
	select
		coalesce(tb.user_id, p.user_id) as user_id,
		coalesce(tb.browser_type, p.browser_type) as browser_type,
		coalesce(tb.datelist[1], (p.date + interval '1 days')::date) as date,
		case 
			when tb.user_id is null
				then p.datelist
			when p.user_id is null
				then tb.datelist
			else
				tb.datelist || p.datelist
		end as datelist
	from prev_udc_typed as p
	full outer join today_browsers as tb
		on p.user_id = tb.user_id
		and p.browser_type = tb.browser_type
)
select 
	user_id, 
	date,
	json_object_agg(browser_type, datelist order by browser_type) as device_activity_datelist
from j_json_exploded
group by user_id, date
;



----------------------------------------------------------------
-- # A datelist_int generation query. 
-- Convert the device_activity_datelist column into a datelist_int column


with udc as (
	select * 
	from user_devices_cumulated
	--where user_id = '13852077118043200000'
),
udc_typed as (
	select
	udc.user_id, 
	udc.date, 
	exploded_json.key as browser_type,
	array_agg(exploded_array::date) as datelist
	from udc 
	join lateral json_each(device_activity_datelist) as exploded_json
		on 1=1
	join lateral json_array_elements_text(exploded_json.value) as exploded_array
		on 1=1
	group by udc.user_id, udc.date, exploded_json.key
),
udc_datelist_int as (
	select
	udct.user_id,
	udct.date,
	udct.browser_type,
	udct.datelist, -- just for verifiability
	sum(
		case 
			when udct.datelist @> array[gn::date]
				then pow(2, 6 + (gn::date - udct.date))::integer
			else 0
		end
	)::bit(7) as datelist_int
	from udc_typed as udct
	join lateral generate_series(udct.date - interval '6 days', udct.date, interval '1 days') as gn
		on 1=1
	group by udct.user_id, udct.date, udct.browser_type, udct.datelist
)
select
user_id,
date,
json_object_agg(browser_type, datelist_int order by browser_type) as device_activity_datelist_int
from udc_datelist_int
group by user_id, date
order by user_id, date
;


-- # A DDL for hosts_cumulated table
--   - a host_activity_datelist which logs to see which dates each host
--     is experiencing any activity


create table hosts_cumulated (
	host text,
	date date,
	host_activity_datelist date[],
	primary key (host, date)
)
;
-- host_activity_datelist (on last 7 days)

----------------------------------------------------------------
-- # The incremental query to generate host_activity_datelist


insert into hosts_cumulated
with prev_hc as (
	select
	*
	from hosts_cumulated
	where date='2023-01-07'
),
prev_hc_t as (
	select
		host, date,
		array_agg(unn_date order by unn_date desc) as host_activity_datelist_t
	from prev_hc
	join lateral unnest(prev_hc.host_activity_datelist) as unn_date
		on 1=1
	where date - unn_date < 6
	group by host, date
),
today as (
	select 
	host,
	event_time::date as date,
	array[event_time::date] as host_activity_datelist
	from events
	where 
		event_time::date = '2023-01-08'
		and host is not null
	group by host, event_time::date
)
select
coalesce(t.host, phc.host) as host,
coalesce(t.date, (phc.date + interval '1 days')::date) as date,
case 
	when t.host is null
		then phc.host_activity_datelist_t
	when phc.host is null
		then t.host_activity_datelist
	else
		t.host_activity_datelist || phc.host_activity_datelist_t
end as host_activity_datelist
from prev_hc_t phc
full outer join today t
	on phc.host = t.host
;


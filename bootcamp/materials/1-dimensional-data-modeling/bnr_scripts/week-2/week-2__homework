	user_id numeric,
	date date,
	device_activity_datelist json,
	primary key (user_id, date)
)
;
-- device_activity_datelist (on last 7 days)

----------------------------------------------------------------
-- # A cumulative query to generate 'device_activity_datelist' from events

-- Note that PostgreSQL does not have type MAP
-- And if we try to model MAP<STRING, DATE[]> as a JSON,
-- the DATE[] type will not be preserved when writing and will not be recognized when reading.
-- PostgreSQL would simply store them as an array of JSON string, and we would them need to keep casting them back to DATE[].
-- Furthermore, this DATE[] casting requires us to explode the array, cate to DATE, and then aggregate again.
-- This MAP<STRING, DATE[]> typing would make more sense in another engine that preserved the datatypes though (e.g., Spark).
-- We still used it here though, for learning purposes. After all, it will still reduce the table records nevertheless.


-- quick snippet showing this behavior:
select
  'boolean',
  pg_typeof(true)::text,
  jsonb_typeof(to_jsonb(true)),
  to_jsonb(true)
union all 
select
  'date[]',
  pg_typeof(array[date '2026-01-01', date '2026-01-02'])::text,
  jsonb_typeof(to_jsonb(array[date '2026-01-01', date '2026-01-02'])),
  to_jsonb(array[date '2026-01-01', date '2026-01-02'])
;



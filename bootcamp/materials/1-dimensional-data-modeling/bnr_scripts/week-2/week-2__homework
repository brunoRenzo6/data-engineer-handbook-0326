-- # A query to deduplicate game_details from Day 1 so there's no duplicates

-- quick look on the duplicates
with dups as (
	select 
	game_id, player_id, count(*) as c
	from game_details
	group by game_id, player_id
	having count(*) > 1
)
select * 
from game_details as gd
join dups as d
	on gd.game_id = d.game_id
	and gd.player_id = d.player_id
order by gd.game_id, d.player_id
;

-- query to dedup
with a as (
	select
	*,
	row_number() over(partition by game_id, player_id) as rn
	from game_details
)
select * 
from a 
where rn = 1
;


-- # DDL for actors_history_scd table


create table actors_history_scd (
	actor_id varchar,
	actor_name varchar,
	quality_class quality_class,
	is_active boolean,
	start_date integer,
	end_date integer,
	primary key (actor_id, start_date)
)
;


------------------------------------------
-- # Backfill query for actors_history_scd
-- Note that we are modeling SCD type 2 with EXCLUSIVE end_date
-- Also, we are assuming all actors are persisted in the actors table

insert into actors_history_scd
with a as (
	select
	*,
	row_number() over(partition by actor_id order by current_year) as rn,
	lag(quality_class) over(partition by actor_id order by current_year) as prev_quality_class,
	lag(is_active) over(partition by actor_id order by current_year) as prev_is_active
	from actors
)
select
actor_id, 
actor_name,
quality_class, 
is_active,
current_year as start_date,
lead(current_year) over(partition by actor_id order by current_year) as end_date
from a
where rn=1
	or quality_class is distinct from prev_quality_class
	or is_active is distinct from prev_is_active
order by actor_id, current_year
;



select * from actors_history_scd
order by actor_id, start_date
;


------------------------------------------
-- # Incremental query for actors_history_scd
-- Note that we are modeling SCD type 2 with EXCLUSIVE end_date
-- Also, we are assuming all actors are persisted in the actors table

create table actors_history_scd_incr (
	actor_id varchar,
	actor_name varchar,
	quality_class quality_class,
	is_active boolean,
	start_date integer,
	end_date integer,
	primary key (actor_id, start_date)
)
;


create temp table actors_history_scd_incr_tmp as 
select * from actors_history_scd_incr limit 0;

--------------------------
-- ## begin query 

truncate actors_history_scd_incr_tmp;
insert into actors_history_scd_incr_tmp
with new_batch as (
	select 
	actor_id, 
	actor_name,
	quality_class, 
	is_active,
	current_year
	from actors
	where current_year = 2021
),
historical_records as (
	select
	*
	from actors_history_scd_incr
	where end_date is not null
),
open_records as (
	select
	actor_id, 
	actor_name,
	quality_class, 
	is_active,
	start_date as current_year
	from actors_history_scd_incr
	where end_date is null
),
a as ( -- we can then siply apply the standard scd2 process from here onwards
	select * from open_records
	union all
	select * from new_batch
	order by actor_id, current_year
),
b as (
	select
	*,
	row_number() over(partition by actor_id order by current_year) as rn,
	lag(quality_class) over(partition by actor_id order by current_year) as prev_quality_class,
	lag(is_active) over(partition by actor_id order by current_year) as prev_is_active
	from a
),
c as (
	select 
	actor_id, 
	actor_name,
	quality_class,
	is_active,
	current_year as start_date,
	lead(current_year) over(partition by actor_id order by current_year) as end_date
	from b
	where rn=1
		or quality_class is distinct from prev_quality_class
		or is_active is distinct from prev_is_active
)
select * from historical_records
union all
select * from c
;

truncate actors_history_scd_incr;
insert into actors_history_scd_incr
select * from actors_history_scd_incr_tmp
;


-- ## end query 

order by actor_id, start_date


-- Comparing whether the full load and the increamental are equal
select * 
from actors_history_scd as a
full outer join actors_history_scd_incr as i
	on a.actor_id = i.actor_id
	and a.start_date = i.start_date
where a.actor_name is distinct from i.actor_name
or a.quality_class is distinct from i.quality_class
or a.is_active is distinct from i.is_active
or a.end_date is distinct from i.end_date


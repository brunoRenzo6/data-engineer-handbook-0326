-- # DDLs


create type film as (
	film_id varchar,
	name varchar,
	year integer,
	votes integer,
	rating real
)
;

create type quality_class as enum (
	'star', 'good', 'average', 'bad'
)
;


create table actors (
	actor_id varchar,
	actor_name varchar,
	films film[],
	quality_class quality_class,
	is_active boolean,
	current_year integer,
	primary key (actor_id, current_year)
)
;


------------------------------------------
-- ## Cumulative table generation query
-- Write a query that populates the actors table one year at a time
-- So essentially will be cumulative table with SDC1 (one snapshot per year)

-- for brevity, lets work with data from 2010 to 2021 only
select year, count(*) as c 
from actor_films
group by year
order by year desc
;

--note that one actor can work in more than one film in a year
with a as (
	select actorid, year, count(*) as c 
	from actor_films
	group by actorid, year
)
select c, count(*) as cc from a
group by c
order by cc desc
;

-- lets assume there is only one actor name per actor id
select actorid, count(distinct actor) as c
from actor_films
group by actorid
order by c desc
;



insert into actors
with actors_t as (
	select * from actors
	where current_year = 2020
),
new_batch as (
	select * from actor_films
	where year = 2021
),
new_batch_t as (
	select 
	actorid as actor_id,
	min(actor) as actor_name, 
	array_agg(row(
		filmid,
		film, 
		year, 
		votes, 
		rating
	)::film) as films,
	case 
		when avg(rating)>8 then 'star'::quality_class
		when avg(rating)>7 then 'good'::quality_class
		when avg(rating)>6 then 'average'::quality_class
		when avg(rating)<=6 then 'bad'::quality_class
	end as quality_class
	from new_batch
	group by actorid, year
)
select 
	coalesce(nb.actor_id, a.actor_id) as actor_id, 
	coalesce(nb.actor_name, a.actor_name) as actor_name, 
	case 
		when nb.films is null
			then a.films
		when a.films is null 
			then nb.films
		else
			a.films || nb.films
	end as films,
	coalesce(nb.quality_class, a.quality_class) as quality_class, 
	case 
		when nb.actor_id is not null then True 
		else False
	end as is_active,
	coalesce(nb.films[1].year, a.current_year+1) as current_year
from actors_t a 
full outer join new_batch_t nb
	on a.actor_id = nb.actor_id
;



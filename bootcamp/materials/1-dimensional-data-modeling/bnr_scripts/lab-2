-- # ok so lets do an incremental processing now.
-- note that we are doing only an icremental PROCESSING.
-- because we will be still writing the full table.
-- this could be a further improvement though.
-- but it would require us to use UPSERT I guess.


create table players_scd_incr (
	player_name varchar, 
	scoring_class scoring_class, 
	is_active boolean,
	start_season integer,
	end_season integer,
	primary key (player_name, start_season)
);



truncate table players_scd_incr;

insert into players_scd_incr
with last_players_scd as (
	select * 
	from players_scd_v2_2021
	-- it has only data up to season 2021
),
new_players as (
	select * 
	from players
	where current_season = 2022
),
historical_records as (
	select * 
	from last_players_scd
	where end_season is not null
),
open_records as (
	select * 
	from last_players_scd
	where end_season is null
),
new_players_f as (
	select 
		player_name, 
		scoring_class, 
		is_active, 
		current_season as start_season, 
		cast(null as integer) as end_season 
	from new_players
),
open_records_2 as (
	select 
	* 
	from open_records
	union all 
	select * from new_players_f
), -- from now on we can simply apply the usual scd process to these records
a as (
	select 
	*,
	row_number() over (partition by player_name order by start_season) as rn,
	lag(scoring_class) over (partition by player_name order by start_season) as prev_scoring_class,
	lag(is_active) over (partition by player_name order by start_season) as prev_is_active
	from open_records_2
),
open_records_3 as (
	select
	player_name,
	scoring_class, 
	is_active, 
	start_season,
	lead(start_season, 1) over (partition by player_name order by start_season) as end_season
	from a
	where (rn = 1)
		or (scoring_class is distinct from prev_scoring_class)
		or (is_active is distinct from prev_is_active)
)
select * from historical_records
union all 
select * from open_records_3
order by player_name, start_season



-- # Comparing whether the full load and the increamental are equal
select * 
from players_scd_v2 as v2
full outer join players_scd_incr as i
on v2.player_name = i.player_name
	and v2.start_season = i.start_season
where v2.player_name is distinct from i.player_name
or v2.start_season is distinct from i.start_season
or v2.scoring_class is distinct from i.scoring_class
or v2.is_active is distinct from i.is_active
or v2.end_season is distinct from i.end_season
;
-- Ok validated.







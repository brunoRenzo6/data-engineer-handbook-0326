drop table players_scd_v2;
create table players_scd_v2 (
	player_name varchar, 
	scoring_class scoring_class, 
	is_active boolean,
	start_season integer,
	end_season integer,
	primary key (player_name, start_season)
);


-- full load SCD2
insert into players_scd_v1
with a as (
	select 
	player_name,
	scoring_class,
	is_active,
	current_season,
	lag(scoring_class, 1) over (partition by player_name order by current_season) as prev_scoring_class,
	lag(is_active, 1) over (partition by player_name order by current_season) as prev_is_active
	from players
	order by player_name 
),
b as (
	select 
	*,
	case 
		when (prev_scoring_class != scoring_class) or (prev_is_active != is_active)
			then 1 
		else 0 end as change_indicator
	from a
),
c as (
	select
	*,
	sum(change_indicator) over (partition by player_name order by current_season) as streak_identifier
	from b
)
select 
player_name, 
scoring_class, 
is_active,
min(current_season) as start_season,
max(current_season) as end_season
from c
group by player_name, streak_identifier, scoring_class, is_active
order by player_name, start_season






-- a more eficient way to do full load SCD2
truncate table players_scd_v2_2021;
insert into players_scd_v2_2021
with a as (
	select 
	player_name,
	scoring_class,
	is_active,
	current_season,
	row_number() over (partition by player_name order by current_season) as rn,
	lag(scoring_class, 1) over (partition by player_name order by current_season) as prev_scoring_class,
	lag(is_active, 1) over (partition by player_name order by current_season) as prev_is_active
	from players
	where current_season <= 2021 --hard cutoff to simulate incremental process later
),
b as (
	select 
	*,
	case 
		when rn = 1 
			then 1
		when (prev_scoring_class is distinct from scoring_class) or (prev_is_active is distinct from is_active)
			then 1 
		else 0 end as change_indicator
	from a
),
c as (
	select * from b
	where change_indicator = 1
)
select 
player_name, 
scoring_class, 
is_active,
current_season as start_season,
lead(current_season) over (partition by player_name order by current_season) as end_season
from c
order by player_name, current_season


select * from players_scd_v2



-- # checking the diffs between the two
-- esentially the same, but while _v1 has end_season inclusive,
-- _v2 has end_season exclusive
select * 
from players_scd_v1 as v1
full outer join players_scd_v2 as v2
on v1.player_name = v2.player_name
	and v1.start_season = v2.start_season
where v1.player_name is distinct from v2.player_name
or v1.start_season is distinct from v2.start_season
or v1.scoring_class is distinct from v2.scoring_class
or v1.is_active is distinct from v2.is_active
or v1.end_season is distinct from v2.end_season
;
-- Ok validated.


